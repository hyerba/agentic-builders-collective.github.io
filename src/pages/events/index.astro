---
import BaseLayout from "../../layouts/BaseLayout.astro";
import QRCode from "../../components/QRCode.astro";
import { getCollection } from "astro:content";
import { contributionLinks } from "../../lib/contribution-links";
import { buildEventIndex, getLinkedEvent } from "../../lib/relations";
import { recaps } from "../../lib/recaps";

const allEvents = await getCollection("events");
const allPresentations = await getCollection("presentations");
const eventsById = buildEventIndex(allEvents);
const presentationsByEventId = new Map<string, typeof allPresentations>();
for (const presentation of allPresentations) {
  const event = getLinkedEvent(presentation.data.eventId, eventsById, `presentation "${presentation.data.id}"`);
  if (!presentationsByEventId.has(event.id)) {
    presentationsByEventId.set(event.id, []);
  }

  presentationsByEventId.get(event.id)!.push(presentation);
}

for (const [, presentations] of presentationsByEventId) {
  presentations.sort((a, b) => a.data.title.localeCompare(b.data.title));
}

const getEventPresentations = (eventId: string) => presentationsByEventId.get(eventId) ?? [];
const now = new Date();
const formatTime = (time: string) => time.replace(/\s*SGT$/, "");
const formatDateKey = (value: Date | string) => {
  const date = value instanceof Date ? value : new Date(value);
  return `${date.getUTCFullYear()}-${String(date.getUTCMonth() + 1).padStart(2, "0")}-${String(date.getUTCDate()).padStart(2, "0")}`;
};
const getClosesText = (survey?: {
  closesAt?: Date | string;
  closesAtLabel?: string;
}) => {
  if (!survey?.closesAt) return "";
  if (survey.closesAtLabel?.trim()) return survey.closesAtLabel.trim();
  return `Closes ${new Date(survey.closesAt).toLocaleDateString("en-SG", { month: "short", day: "numeric" })}`;
};
const hasFeedbackResults = (feedback?: {
  rating?: number;
  responses?: number;
  highlights?: string[];
}) => typeof feedback?.rating === "number" || (feedback?.responses ?? 0) > 0 || (feedback?.highlights?.length ?? 0) > 0;
const extraSponsorsByEventId: Record<string, { name: string; url: string }[]> = {
  "2026-03-27-abc-at-google": [
    {
      name: "Google Singapore",
      url: "https://google.com",
    },
  ],
  "2026-04-23-abc-at-lorong-ai": [
    {
      name: "Lorong AI",
      url: "https://lorong.ai/",
    },
  ],
  "2026-05-28-abc-at-amcham": [
    {
      name: "American Chamber of Commerce in Singapore",
      url: "https://www.amcham.com.sg",
    },
  ],
};

const upcoming = allEvents
  .filter((e) => e.data.status === "upcoming" || new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = allEvents
  .filter((e) => e.data.status === "past" && new Date(e.data.date) < now)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const pastMeetups = past.filter((event) => event.data.kind !== "learning");
const pastLearning = past.filter((event) => event.data.kind === "learning");
---

<BaseLayout
  title="events"
  description="See upcoming meetups, workshops, and past sessions from Agentic Builders Collective in Singapore."
>
  <style>
    .events-muted-link::after {
      content: none;
    }

    .events-register {
      justify-self: start;
    }

    .survey-section {
      margin-top: 16px;
      padding: 16px;
      background: var(--box-bg, rgba(30, 30, 40, 0.45));
    }

    .survey-title {
      font-weight: 600;
      color: var(--accent);
      margin-bottom: 8px;
    }

    .survey-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: var(--accent);
      text-decoration: underline;
      font-weight: 500;
    }

    .survey-link:hover {
      color: var(--text);
      text-decoration: underline;
    }

    .feedback-section {
      margin-top: 16px;
      padding: 16px;
      background: var(--box-bg, rgba(30, 30, 40, 0.45));
    }

    .feedback-highlight {
      padding: 8px 0;
      border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.08));
    }

    .feedback-rating {
      font-size: 1rem;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 8px;
    }

    .feedback-rating-meta {
      font-size: 1rem;
      font-weight: 400;
      color: var(--muted);
    }

    .feedback-highlight:last-child {
      border-bottom: none;
    }

    .survey-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .survey-actions > .button {
      border-color: transparent;
      min-height: 42px;
    }

    .events-survey-meta {
      margin-top: 6px;
      color: var(--muted);
      opacity: 0.65;
      font-size: 1rem;
      line-height: 1.25;
    }

    .events-empty-state {
      color: var(--muted);
      opacity: 0.65;
    }

    .events-survey-button {
      background: rgba(215, 228, 248, 0.09);
      border-color: rgba(215, 228, 248, 0.22);
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      gap: 4px;
      line-height: 1.25;
      white-space: nowrap;
    }

    .events-survey-button:hover {
      background: rgba(215, 228, 248, 0.12);
      color: var(--text);
    }

    .events-survey-meta-inline {
      margin-left: 4px;
      color: var(--muted);
      opacity: 0.65;
      font-size: 1rem;
    }

    .events-panel-toggle {
      align-items: center;
      background: rgba(215, 228, 248, 0.04);
      cursor: pointer;
      display: inline-flex;
      justify-content: center;
      min-width: 48px;
      padding-left: 12px;
      padding-right: 12px;
    }

    .events-panel-toggle[aria-disabled="true"] {
      border-color: var(--line);
      color: var(--muted);
      cursor: not-allowed;
      opacity: 0.45;
    }

    .events-panel-toggle[aria-expanded="true"] {
      background: rgba(215, 228, 248, 0.08);
      color: var(--text);
    }

    .events-panel-icon {
      display: block;
      height: 18px;
      width: 18px;
    }

    .events-panel-content.is-hidden {
      display: none;
    }

    .qr-section {
      margin-top: 16px;
      text-align: left;
    }

    .qr-label {
      font-size: 1rem;
      color: var(--muted);
      margin-top: 12px;
    }

    .events-panel-section.is-hidden {
      display: none;
    }

    .recap-section {
      margin-top: 16px;
      padding: 16px;
      background: var(--box-bg, rgba(30, 30, 40, 0.45));
      display: grid;
      gap: 12px;
    }

    .recap-player {
      width: 100%;
    }

    .recap-listen-toggle {
      gap: 6px;
    }

    .events-section {
      display: block;
    }

    .collapsible-heading {
      align-items: center;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      list-style: none;
      width: 100%;
    }

    .collapsible-heading::-webkit-details-marker {
      display: none;
    }

    .collapsible-heading::after {
      color: #555;
      content: "[+]";
      margin-left: auto;
    }

    .events-section[open] > .collapsible-heading::after {
      content: "[-]";
    }

    .event-related-links {
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      font-size: 1rem;
      gap: 6px;
    }

    .event-related-link {
      color: var(--accent);
      font-size: 1rem;
      text-decoration: none;
    }

    .event-related-link:hover,
    .event-related-link:focus-visible {
      text-decoration: underline;
    }
  </style>

  <h1 class="page-title">Events</h1>

  <section>
    <h3 class="section-label">Upcoming</h3>
    {upcoming.length === 0 ? (
      <div class="card">
        <p>Stay tuned for the next event!</p>
      </div>
    ) : (
      <div class="list">
        {upcoming.map((event) => (
          <div class="list-item" id={event.id}>
            {(() => {
              const preSurvey = event.data.preEventSurvey;
              const qrPanelId = `pre-survey-${event.id}`;
              const feedbackPanelId = `feedback-${event.id}`;
              const closesText = getClosesText(preSurvey);
              const showActionButtons = !!(event.data.registrationUrl || preSurvey?.url);
              const closesInsideSurvey = closesText && preSurvey?.url && preSurvey.closesAtPlacement === "inside";
              const closesOutsideSurvey = closesText && preSurvey?.url && preSurvey.closesAtPlacement === "outside";
              const hasResults = hasFeedbackResults(event.data.feedback);
              return (
                <>
                  <div class="list-item-header">
                    {event.data.registrationUrl ? (
                      <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
                    ) : (
                      <span class="list-item-title">{event.data.title}</span>
                    )}
                    <div class="card-meta">
                      <span>{new Date(event.data.date).toLocaleDateString("en-SG", { weekday: "short", year: "numeric", month: "short", day: "numeric" })}</span>
                      {event.data.time && <span>{formatTime(event.data.time)}</span>}
                      {event.data.sponsorName && (
                        <span>
                          {event.data.sponsorUrl ? (
                            <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                          ) : (
                            event.data.sponsorName
                          )}
                          {(extraSponsorsByEventId[event.id] ?? []).map((sponsor) => (
                            <>
                              {" + "}
                              <a class="muted-link events-muted-link" href={sponsor.url} target="_blank" rel="noopener">{sponsor.name}</a>
                            </>
                          ))}
                        </span>
                      )}
                    </div>
                  </div>
                  {(() => {
                    const eventPresentations = getEventPresentations(event.id);
                    return eventPresentations.length > 0 && (
                      <div class="event-related-links">
                        <span>Presentations</span>
                        {eventPresentations.map((presentation, index) => (
                          <a class="event-related-link" href={`/showcase/#${presentation.data.id}`} title={presentation.data.title}>[{index + 1}]</a>
                        ))}
                      </div>
                    );
                  })()}
                  {showActionButtons && (
                    <div class="survey-actions">
                      {event.data.registrationUrl && (
                        <a class="button button-primary events-register" href={event.data.registrationUrl} target="_blank" rel="noopener">
                          Register <span class="inline-arrow" aria-hidden="true">▶</span>
                        </a>
                      )}
                      {preSurvey?.url && (
                        <a class="button button-secondary events-survey-button" href={preSurvey.url} target="_blank" rel="noopener">
                          <span>{preSurvey.takeSurveyLabel || "Take survey"}</span>
                          <span class="inline-arrow" aria-hidden="true">▶</span>
                          {closesInsideSurvey && <span class="events-survey-meta-inline">{closesText}</span>}
                        </a>
                      )}
                      {preSurvey?.url && preSurvey.qrEnabled && (
                        <button
                          type="button"
                          class="button button-secondary events-panel-toggle"
                          data-panel-toggle={qrPanelId}
                          data-show-label={preSurvey.qrToggleLabel || "Show survey QR"}
                          data-hide-label="Hide survey QR"
                          aria-controls={qrPanelId}
                          aria-expanded="false"
                          aria-label={preSurvey.qrToggleLabel || "Show survey QR"}
                          title={preSurvey.qrToggleLabel || "Show survey QR"}
                          aria-disabled="false"
                        >
                          <svg class="events-panel-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M4 4H10V10H4V4ZM6 6V8H8V6H6ZM14 4H20V10H14V4ZM16 6V8H18V6H16ZM4 14H10V20H4V14ZM6 16V18H8V16H6ZM12 12H14V14H12V12ZM14 14H16V16H14V14ZM12 16H14V18H12V16ZM16 16H18V18H16V16ZM18 12H20V14H18V12ZM18 18H20V20H18V18ZM16 20H18V22H16V20ZM20 16H22V18H20V16Z" fill="currentColor" />
                          </svg>
                        </button>
                      )}
                      {preSurvey?.feedbackEnabled && (
                        <button
                          type="button"
                          class="button button-secondary events-panel-toggle"
                          data-panel-toggle={feedbackPanelId}
                          data-show-label={preSurvey.feedbackToggleLabel || "Show survey results"}
                          data-hide-label="Hide survey results"
                          aria-controls={feedbackPanelId}
                          aria-expanded="false"
                          aria-label={preSurvey.feedbackToggleLabel || "Show survey results"}
                          title={preSurvey.feedbackToggleLabel || "Show survey results"}
                          aria-disabled="false"
                        >
                          <svg class="events-panel-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M5 6H19V16H9L5 20V6ZM7 8V15.17L8.17 14H17V8H7ZM9 10H15V12H9V10Z" fill="currentColor" />
                          </svg>
                        </button>
                      )}
                    </div>
                  )}
                  {preSurvey?.url && preSurvey.qrEnabled && (
                    <>
                      <div id={qrPanelId} class="survey-section events-panel-section is-hidden" data-panel>
                        <div class="survey-title">{preSurvey.qrSectionTitle || "Share your feedback"}</div>
                        <div
                          class={`events-empty-state${formatDateKey(now) < formatDateKey(preSurvey.qrOpensAt || event.data.date) ? "" : " is-hidden"}`}
                          data-panel-empty
                          data-unlock-date={formatDateKey(preSurvey.qrOpensAt || event.data.date)}
                        >
                          Nothing here yet
                        </div>
                        <div
                          class={`events-panel-content${formatDateKey(now) < formatDateKey(preSurvey.qrOpensAt || event.data.date) ? " is-hidden" : ""}`}
                          data-panel-content
                          data-unlock-date={formatDateKey(preSurvey.qrOpensAt || event.data.date)}
                        >
                          <div class="qr-section" style="margin-bottom: 16px;">
                            <QRCode url={preSurvey.url} size={150} />
                            {preSurvey.qrHintText && <div class="qr-label">{preSurvey.qrHintText}</div>}
                          </div>
                          <a class="survey-link" href={preSurvey.url} target="_blank" rel="noopener" style="margin-top: 12px;">
                            Open survey ▶
                          </a>
                        </div>
                      </div>
                    </>
                  )}
                  {preSurvey?.feedbackEnabled && (
                    <div id={feedbackPanelId} class="feedback-section events-panel-section is-hidden" data-panel>
                      <div class="survey-title">{preSurvey.feedbackSectionTitle || "Survey results"}</div>
                      {!hasResults && (
                        <div class="events-empty-state">Nothing here yet</div>
                      )}
                      {typeof event.data.feedback?.rating === "number" && (
                        <div class="feedback-rating">
                          ★ {event.data.feedback.rating.toFixed(1)}{" "}
                          <span class="feedback-rating-meta">
                            ({event.data.feedback.responses} responses)
                          </span>
                        </div>
                      )}
                      {typeof event.data.feedback?.rating !== "number" && (event.data.feedback?.responses ?? 0) > 0 && (
                        <div class="feedback-rating-meta">({event.data.feedback?.responses} responses)</div>
                      )}
                      {event.data.feedback?.highlights && event.data.feedback.highlights.length > 0 && (
                        <div>
                          {event.data.feedback.highlights.map((highlight) => (
                            <div class="feedback-highlight">"{highlight}"</div>
                          ))}
                        </div>
                      )}
                    </div>
                  )}
                  {closesOutsideSurvey && (
                    <div class="events-survey-meta">{closesText}</div>
                  )}
                </>
              );
            })()}
          </div>
        ))}
      </div>
    )}
  </section>

  <details class="events-section">
    <summary class="section-label collapsible-heading">Past Meetups</summary>
    {pastMeetups.length === 0 ? (
      <p>No past events yet. <a class="muted-link" href={contributionLinks.event} target="_blank" rel="noopener">Add an event by submitting a pull request</a></p>
    ) : (
      <div class="list">
        {pastMeetups.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                    {(extraSponsorsByEventId[event.id] ?? []).map((sponsor) => (
                      <>
                        {" + "}
                        <a class="muted-link events-muted-link" href={sponsor.url} target="_blank" rel="noopener">{sponsor.name}</a>
                      </>
                    ))}
                  </span>
                )}
              </div>
            </div>
            {(() => {
              const eventPresentations = getEventPresentations(event.id);
              return eventPresentations.length > 0 && (
                <div class="event-related-links">
                  <span>Presentations</span>
                  {eventPresentations.map((presentation, index) => (
                    <a class="event-related-link" href={`/showcase/#${presentation.data.id}`} title={presentation.data.title}>[{index + 1}]</a>
                  ))}
                </div>
              );
            })()}
            
            {/* Post-event survey with QR */}
            {event.data.postEventSurvey?.url && event.data.postEventSurvey?.qrEnabled && (
              <div class="survey-section">
                <div class="survey-title">📱 Share your feedback</div>
                <div class="qr-section">
                  <QRCode url={event.data.postEventSurvey.url} size={150} />
                  <div class="qr-label">Scan to rate this event</div>
                </div>
                <a class="survey-link" href={event.data.postEventSurvey.url} target="_blank" rel="noopener" style="margin-top: 12px;">
                  Open survey ▶
                </a>
              </div>
            )}
            
            {/* Feedback results */}
            {event.data.feedback && hasFeedbackResults(event.data.feedback) && (
              <div class="feedback-section">
                {typeof event.data.feedback.rating === "number" && (
                  <div class="feedback-rating">
                    ★ {event.data.feedback.rating.toFixed(1)}{" "}
                    <span class="feedback-rating-meta">
                      ({event.data.feedback.responses} responses)
                    </span>
                  </div>
                )}
                {typeof event.data.feedback.rating !== "number" && (event.data.feedback.responses ?? 0) > 0 && (
                  <div class="feedback-rating-meta">
                    ({event.data.feedback.responses} responses)
                  </div>
                )}
                {event.data.feedback.highlights && event.data.feedback.highlights.length > 0 && (
                  <div>
                    {event.data.feedback.highlights.map((highlight) => (
                      <div class="feedback-highlight">"{highlight}"</div>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </details>

  <details class="events-section" open>
    <summary class="section-label collapsible-heading">Recaps</summary>
    <p class="collection-guide">
      AI-generated audio summaries of the past week's WhatsApp chat highlights — handy if you missed anything.
    </p>
    {recaps.length === 0 ? (
      <p>No recaps yet.</p>
    ) : (
      <div class="list">
        {recaps.map((recap) => {
          const panelId = `recap-panel-${recap.id}`;
          return (
            <div class="list-item" id={recap.id}>
              <div class="list-item-header">
                <span class="list-item-title">{recap.title}</span>
                <div class="card-meta">
                  <span>{new Date(recap.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}</span>
                  <span>{recap.durationLabel}</span>
                  <span>AI-generated</span>
                </div>
              </div>
              <div class="survey-actions">
                <button
                  type="button"
                  class="button button-secondary events-panel-toggle recap-listen-toggle"
                  data-panel-toggle={panelId}
                  data-show-label="Listen to recap"
                  data-hide-label="Hide recap"
                  data-show-text="Listen"
                  data-hide-text="Hide"
                  aria-controls={panelId}
                  aria-expanded="false"
                  aria-label="Listen to recap"
                  title="Listen to recap"
                >
                  <span>Listen</span>
                  <span class="inline-arrow" aria-hidden="true">▶</span>
                </button>
              </div>
              <div id={panelId} class="recap-section events-panel-section is-hidden" data-panel>
                <p>{recap.description}</p>
                <audio class="recap-player" controls preload="metadata" src={recap.audio}>
                  <a href={recap.audio}>Download audio (m4a)</a>
                </audio>
                <a class="muted-link" href={recap.audio} download>Download m4a</a>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </details>

  <details class="events-section" open>
    <summary class="section-label collapsible-heading">Learning</summary>
    {pastLearning.length === 0 ? (
      <p>No learning sessions yet. <a class="muted-link" href={contributionLinks.event} target="_blank" rel="noopener">Add a learning event by submitting a pull request</a></p>
    ) : (
      <div class="list">
        {pastLearning.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                    {(extraSponsorsByEventId[event.id] ?? []).map((sponsor) => (
                      <>
                        {" + "}
                        <a class="muted-link events-muted-link" href={sponsor.url} target="_blank" rel="noopener">{sponsor.name}</a>
                      </>
                    ))}
                  </span>
                )}
              </div>
            </div>
            {(() => {
              const eventPresentations = getEventPresentations(event.id);
              return eventPresentations.length > 0 && (
                <div class="event-related-links">
                  <span>Presentations</span>
                  {eventPresentations.map((presentation, index) => (
                    <a class="event-related-link" href={`/showcase/#${presentation.data.id}`} title={presentation.data.title}>[{index + 1}]</a>
                  ))}
                </div>
              );
            })()}
            
            {/* Post-event survey with QR */}
            {event.data.postEventSurvey?.url && event.data.postEventSurvey?.qrEnabled && (
              <div class="survey-section">
                <div class="survey-title">📱 Share your feedback</div>
                <div class="qr-section">
                  <QRCode url={event.data.postEventSurvey.url} size={150} />
                  <div class="qr-label">Scan to rate this event</div>
                </div>
                <a class="survey-link" href={event.data.postEventSurvey.url} target="_blank" rel="noopener" style="margin-top: 12px;">
                  Open survey ▶
                </a>
              </div>
            )}
            
            {/* Feedback results */}
            {event.data.feedback && hasFeedbackResults(event.data.feedback) && (
              <div class="feedback-section">
                {typeof event.data.feedback.rating === "number" && (
                  <div class="feedback-rating">
                    ★ {event.data.feedback.rating.toFixed(1)}{" "}
                    <span class="feedback-rating-meta">
                      ({event.data.feedback.responses} responses)
                    </span>
                  </div>
                )}
                {typeof event.data.feedback.rating !== "number" && (event.data.feedback.responses ?? 0) > 0 && (
                  <div class="feedback-rating-meta">
                    ({event.data.feedback.responses} responses)
                  </div>
                )}
                {event.data.feedback.highlights && event.data.feedback.highlights.length > 0 && (
                  <div>
                    {event.data.feedback.highlights.map((highlight) => (
                      <div class="feedback-highlight">"{highlight}"</div>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </details>

  <script>
    const getLocalDateKey = (date: Date) => {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    };

    const panelToggles = document.querySelectorAll("[data-panel-toggle]");
    panelToggles.forEach((toggle) => {
      const panelId = toggle.getAttribute("data-panel-toggle");
      if (!panelId) {
        return;
      }

      const panel = document.getElementById(panelId);
      if (!panel) {
        return;
      }

      const showLabel = toggle.getAttribute("data-show-label") || "Show survey QR";
      const hideLabel = toggle.getAttribute("data-hide-label") || "Hide survey QR";
      toggle.setAttribute("aria-disabled", "false");
      toggle.setAttribute("aria-label", showLabel);
      toggle.setAttribute("title", showLabel);

      const gatedContent = panel.querySelectorAll("[data-panel-content]");
      gatedContent.forEach((content) => {
        const unlockDate = content.getAttribute("data-unlock-date");
        const isUnlocked = !unlockDate || getLocalDateKey(new Date()) >= unlockDate;
        content.classList.toggle("is-hidden", !isUnlocked);
      });

      const emptyStates = panel.querySelectorAll("[data-panel-empty]");
      emptyStates.forEach((emptyState) => {
        const unlockDate = emptyState.getAttribute("data-unlock-date");
        const isUnlocked = !unlockDate || getLocalDateKey(new Date()) >= unlockDate;
        emptyState.classList.toggle("is-hidden", isUnlocked);
      });

      toggle.addEventListener("click", () => {
        const nowHidden = panel.classList.toggle("is-hidden");
        const isVisible = !nowHidden;
        const nextLabel = isVisible ? hideLabel : showLabel;
        toggle.setAttribute("aria-expanded", String(isVisible));
        toggle.setAttribute("aria-label", nextLabel);
        toggle.setAttribute("title", nextLabel);
        const showText = toggle.getAttribute("data-show-text");
        const hideText = toggle.getAttribute("data-hide-text");
        if (showText && hideText) {
          const textSpan = toggle.querySelector("span:not([aria-hidden])");
          if (textSpan) textSpan.textContent = isVisible ? hideText : showText;
        }
      });
    });
  </script>
</BaseLayout>
