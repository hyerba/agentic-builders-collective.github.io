---
import "../styles/global.css";
import SiteHead from "../components/SiteHead.astro";
import { getCollection } from "astro:content";
import { contributionLinks } from "../lib/contribution-links";
import { latestRecap } from "../lib/recaps";

const allEvents = await getCollection("events");
const allFaq = await getCollection("faq");
const homepageFaq = allFaq.sort((a, b) => a.data.order - b.data.order);

const now = new Date();
const upcomingEvent = allEvents
  .filter((e) => e.data.status === "upcoming" || new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())[0] ?? null;

const whatsappUrl = "https://chat.whatsapp.com/Be8X9lVJQET4JfkKMW5Qxn";

/** Scales base timings (0.8 then ×0.75 ≈ another 25% faster). */
const SPEED = 0.6;
/** Seconds between each block (glyph) reveal; tuned so ASCII + rule + tagline land in ~5–10s. */
const GLYPH_GAP_SEC = 0.041 * SPEED;
/** Extra pause after each ASCII row before the next line begins. */
const LINE_PAUSE_SEC = 0.13 * SPEED;
const RULE_DRAW_SEC = 0.55 * SPEED;
const AFTER_ASCII_PAUSE_SEC = 0.14 * SPEED;
const AFTER_RULE_PAUSE_SEC = 0.38 * SPEED;
const GLYPH_ANIM_SEC = 0.38 * SPEED;
/** Tagline reveal: 1.5× = 50% slower than ASCII cadence. */
const TAGLINE_SLOW_MULT = 1.5;
const TAGLINE_GLYPH_GAP_SEC = GLYPH_GAP_SEC * TAGLINE_SLOW_MULT;
const TAGLINE_GLYPH_ANIM_SEC = GLYPH_ANIM_SEC * TAGLINE_SLOW_MULT;
const COLOUR_SPAN_PATTERN = /<span style="color:(#[0-9a-f]{6})">([^<]*)<\/span>/gi;
const DIM_COLOUR_THRESHOLD = 140;

function injectGlyphsSequential(
  html: string,
  startSec: number,
  gapSec: number = GLYPH_GAP_SEC
): { html: string; cursorSec: number } {
  let t = startSec;
  const out = html.replace(/<span style="([^"]*)"/g, (_, styles) => {
    const delay = t;
    t += gapSec;
    return `<span class="logo-glyph" style="${styles};--logo-del:${delay.toFixed(3)}s"`;
  });
  return { html: out, cursorSec: t };
}

function wrapAsciiLineByLine(html: string): { html: string; asciiEndSec: number } {
  /** trimEnd only: export HTML keeps a leading space on row 1; full trim() strips it and misaligns the grid. */
  const lines = html.replace(/\r\n/g, "\n").trimEnd().split("\n");
  let cursor = 0;
  const parts = lines.map((line, idx) => {
    const { html: inner, cursorSec } = injectGlyphsSequential(line, cursor, GLYPH_GAP_SEC);
    cursor = cursorSec;
    if (idx < lines.length - 1) cursor += LINE_PAUSE_SEC;
    return `<div class="ascii-line">${inner}</div>`;
  });
  return { html: parts.join(""), asciiEndSec: cursor };
}

function getColourBrightness(hex: string): number {
  const value = Number.parseInt(hex.slice(1), 16);
  const red = (value >> 16) & 255;
  const green = (value >> 8) & 255;
  const blue = value & 255;
  return (red + green + blue) / 3;
}

function decorateAsciiHtml(html: string): string {
  const lines = html.replace(/\r\n/g, "\n").trimEnd().split("\n");
  const totalRows = Math.max(lines.length - 1, 1);

  return lines
    .map((line, rowIndex) => {
      const t = rowIndex / totalRows;

      return line.replace(COLOUR_SPAN_PATTERN, (_, colour: string, char: string) => {
        const isDim = getColourBrightness(colour) < DIM_COLOUR_THRESHOLD;
        const cycleAttribute = char.trim() ? " data-logo-cycle" : "";
        return `<span style="color:${colour}" data-logo-t="${t.toFixed(4)}" data-logo-dim="${isDim}"${cycleAttribute}>${char}</span>`;
      });
    })
    .join("\n");
}

function decorateTaglineHtml(html: string): string {
  const spanCount = [...html.matchAll(COLOUR_SPAN_PATTERN)].length;
  const totalGlyphs = Math.max(spanCount - 1, 1);
  let glyphIndex = 0;

  return html.replace(COLOUR_SPAN_PATTERN, (_, colour: string, char: string) => {
    const t = glyphIndex / totalGlyphs;
    glyphIndex += 1;
    return `<span style="color:${colour}" data-logo-t="${t.toFixed(4)}" data-logo-cycle>${char}</span>`;
  });
}

const asciiHtml = ` <span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#5a5e65">╗</span>  <span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#5a5e65">╗</span><span style="color:#5a5e65"> </span>  <span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#5a5e65">╗</span>
<span style="color:#dde8fa">█</span><span style="color:#dde8fa">█</span><span style="color:#585d64">╔</span><span style="color:#585d64">═</span><span style="color:#585d64">═</span><span style="color:#dde8fa">█</span><span style="color:#dde8fa">█</span><span style="color:#585d64">╗</span> <span style="color:#dde8fa">█</span><span style="color:#dde8fa">█</span><span style="color:#585d64">╔</span><span style="color:#585d64">═</span><span style="color:#585d64">═</span><span style="color:#dde8fa">█</span><span style="color:#dde8fa">█</span><span style="color:#585d64">╗</span> <span style="color:#dde8fa">█</span><span style="color:#dde8fa">█</span><span style="color:#585d64">╔</span><span style="color:#585d64">═</span><span style="color:#585d64">═</span><span style="color:#585d64">═</span><span style="color:#585d64">═</span><span style="color:#585d64">╝</span>
<span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#575c63">║</span> <span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#575c63">╔</span><span style="color:#575c63">╝</span> <span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#575c63">║</span><span style="color:#575c63"> </span><span style="color:#575c63"> </span><span style="color:#575c63"> </span><span style="color:#575c63"> </span><span style="color:#575c63"> </span>
<span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">╔</span><span style="color:#565b63">═</span><span style="color:#565b63">═</span><span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">║</span> <span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">╔</span><span style="color:#565b63">═</span><span style="color:#565b63">═</span><span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">╗</span> <span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">║</span><span style="color:#565b63"> </span><span style="color:#565b63"> </span><span style="color:#565b63"> </span><span style="color:#565b63"> </span><span style="color:#565b63"> </span>
<span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">║</span><span style="color:#d2e0f5"> </span><span style="color:#d2e0f5"> </span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">║</span> <span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">╔</span><span style="color:#545a62">╝</span> <span style="color:#545a62">╚</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">╗</span>
<span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">╝</span><span style="color:#535961"> </span><span style="color:#535961"> </span><span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">╝</span> <span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">╝</span><span style="color:#535961"> </span> <span style="color:#535961"> </span><span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">╝</span>`;

const taglineHtml = `<span style="color:#e0eafc">a</span><span style="color:#dfeafc">g</span><span style="color:#dfe9fb">e</span><span style="color:#dee9fb">n</span><span style="color:#dde8fb">t</span><span style="color:#dde8fa">i</span><span style="color:#dce7fa">c</span> <span style="color:#dbe6f9">b</span><span style="color:#dae6f9">u</span><span style="color:#d9e5f9">i</span><span style="color:#d9e5f8">l</span><span style="color:#d8e4f8">d</span><span style="color:#d8e4f8">e</span><span style="color:#d7e4f7">r</span><span style="color:#d6e3f7">s</span> <span style="color:#d5e2f6">c</span><span style="color:#d4e2f6">o</span><span style="color:#d4e1f5">l</span><span style="color:#d3e1f5">l</span><span style="color:#d2e0f5">e</span><span style="color:#d2e0f4">c</span><span style="color:#d1dff4">t</span><span style="color:#d0dff4">i</span><span style="color:#d0def3">v</span><span style="color:#cfdef3">e</span>`;

const { html: asciiAnimatedHtml, asciiEndSec } = wrapAsciiLineByLine(decorateAsciiHtml(asciiHtml));

const ruleRevealDelaySec = asciiEndSec + AFTER_ASCII_PAUSE_SEC;
const taglineStartSec = ruleRevealDelaySec + RULE_DRAW_SEC + AFTER_RULE_PAUSE_SEC;

const { html: taglineAnimatedHtml, cursorSec: taglineEndSec } = injectGlyphsSequential(
  decorateTaglineHtml(taglineHtml),
  taglineStartSec,
  TAGLINE_GLYPH_GAP_SEC
);

const navLinks = [
  { href: "/about/", label: "about" },
  { href: "/community/", label: "community" },
  { href: "/showcase/", label: "showcase" },
  { href: "/events/", label: "events" }
];

const isCurrent = (href: string) => {
  if (href === "/") {
    return Astro.url.pathname === "/";
  }

  return Astro.url.pathname.startsWith(href);
};
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SiteHead
      title="abc"
      description="Agentic Builders Collective is a Singapore community for developers and builders exploring agentic coding with Claude Code, Codex, Antigravity, meetups, shared projects, and articles."
    />
    <style>
      html { background: #020410; color: #d9e7ff; }
      body { margin: 0; min-height: 100vh; opacity: 0; }
      body.ready { opacity: 1; transition: opacity 80ms ease; }
    </style>
    <style
      define:vars={{
        glyphAnimSec: `${GLYPH_ANIM_SEC.toFixed(3)}s`,
        taglineGlyphAnimSec: `${TAGLINE_GLYPH_ANIM_SEC.toFixed(3)}s`,
        ruleDurFallback: `${RULE_DRAW_SEC.toFixed(3)}s`,
        contactFadeDelaySec: `${taglineEndSec.toFixed(3)}s`
      }}
    >

      :root {
        --logo-reveal-speed: 1;
      }

      body {
        background: transparent;
      }

      .home-shell {
        display: flex;
        flex-direction: column;
        margin: 0 auto;
        max-width: 800px;
        min-height: 100vh;
        padding: 64px 20px 24px;
        width: 100%;
      }

      .home-main {
        align-items: center;
        display: flex;
        flex: 1;
        justify-content: center;
      }

      .logo {
        padding: 40px 72px;
        text-align: center;
      }

      .ascii {
        font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-size: 26px;
        line-height: 1.25;
        font-weight: 800;
        margin-bottom: 8px;
        display: inline-block;
        transform: skewX(-18deg);
      }

      /*
       * Injected markup from set:html has no data-astro-cid; scoped selectors would not match.
       */
      :global(.ascii-line) {
        display: block;
        white-space: pre;
      }

      :global(.logo-glyph) {
        display: inline;
        opacity: 0;
        animation: logoGlyphIn calc(var(--glyphAnimSec) * var(--logo-reveal-speed)) cubic-bezier(0.22, 1, 0.36, 1)
          forwards;
        animation-delay: calc(var(--logo-del, 0s) * var(--logo-reveal-speed));
      }

      :global(.logo-glyph.no-animation) {
        animation: none;
        opacity: 1;
        transform: none;
        filter: none;
      }

      /* Show pointer cursor on colored/interactive logo bits */
      :global([data-logo-cycle]) {
        cursor: pointer;
      }

      @keyframes logoGlyphIn {
        from {
          opacity: 0;
          transform: translateY(0.22em) scale(0.82);
          filter: blur(4px);
        }
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
          filter: blur(0);
        }
      }

      .rule {
        font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-size: 26px;
        white-space: pre;
        margin-bottom: 8px;
      }

      .logo-rule {
        opacity: 0;
        clip-path: inset(0 100% 0 0);
        animation: logoRuleIn calc(var(--logo-rule-dur, var(--ruleDurFallback)) * var(--logo-reveal-speed)) ease forwards;
        animation-delay: calc(var(--logo-del, 0s) * var(--logo-reveal-speed));
      }

      .logo-rule.no-animation {
        animation: none;
        opacity: 0.4;
        clip-path: inset(0 0 0 0);
      }

      @keyframes logoRuleIn {
        to {
          opacity: 0.4;
          clip-path: inset(0 0 0 0);
        }
      }

      .tagline {
        font-family: 'Space Mono', 'Courier New', monospace;
        font-size: 20px;
        font-weight: 400;
        letter-spacing: 4px;
        word-spacing: 8px;
        text-transform: none;
        white-space: nowrap;
        line-height: 1.6;
      }

      /* nav + email handled by global.css */

      .tagline :global(.logo-glyph) {
        animation-duration: calc(var(--taglineGlyphAnimSec) * var(--logo-reveal-speed));
      }

      /* ── Mobile: keep logo within 90vw (5% margin each side) ── */
      @media (max-width: 480px) {
        .logo {
          padding: 40px 5%;
        }

        .ascii {
          font-size: min(26px, 5vw);
        }

        .rule {
          font-size: min(26px, 5vw);
        }

        .tagline {
          font-size: min(20px, 4vw);
          letter-spacing: max(1px, 0.8vw);
          word-spacing: max(2px, 1.6vw);
        }

      }

      /* ── Homepage content sections ── */

      .home-hero-section {
        margin-top: 16px;
        text-align: center;
      }

      .home-hero-tagline {
        color: var(--text);
        font-size: 1rem;
        font-weight: 500;
        line-height: 1.75;
        max-width: 56ch;
        margin: 0 auto;
      }

      .home-hero-sub {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.75;
        margin: 8px auto 0;
        max-width: 56ch;
      }

      .home-hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
        margin-top: 20px;
      }

      .home-recap-notice {
        background: var(--box-bg);
        margin-top: 32px;
        padding: 20px;
      }

      .home-section {
        margin-top: 48px;
      }

      .home-event-register {
        justify-self: start;
      }

      .home-steps {
        display: grid;
        gap: 16px;
      }

      .faq-list {
        display: grid;
        gap: 2px;
      }

      .faq-item {
        border-left: 3px solid var(--line);
        padding: 14px 20px;
        transition: border-color 150ms ease;
      }

      .faq-item[open] {
        border-left-color: var(--accent);
      }

      .faq-question {
        color: var(--text);
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 500;
        list-style: none;
      }

      .faq-question::-webkit-details-marker {
        display: none;
      }

      .faq-question::before {
        content: "+ ";
        color: var(--muted);
        opacity: 0.5;
      }

      .faq-item[open] .faq-question::before {
        content: "- ";
      }

      .faq-answer {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.75;
        margin-top: 10px;
        padding-left: 1.4ch;
      }

      @media (prefers-reduced-motion: reduce) {
        :global(.logo-glyph) {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
        }

        .logo-rule {
          animation: none !important;
          opacity: 0.4 !important;
          clip-path: none !important;
        }
      }
    </style>
  </head>
  <body>
    <nav class="home-top-menu">
      <div class="home-top-links">
        {
          navLinks.map((item) => (
            <a class:list={{ current: isCurrent(item.href) }} href={item.href}>
              {item.label}
            </a>
          ))
        }
        <a href={whatsappUrl} class="nav-cta" target="_blank" rel="noopener">Join WhatsApp <span class="inline-arrow" aria-hidden="true">▶</span></a>
      </div>
      <button class="mobile-hamburger" aria-label="Open menu" aria-expanded="false">
        <svg width="13" height="9" viewBox="0 0 22 16" fill="none" aria-hidden="true">
          <line x1="0" y1="1" x2="22" y2="1" stroke="currentColor" stroke-width="2"/>
          <line x1="0" y1="8" x2="22" y2="8" stroke="currentColor" stroke-width="2"/>
          <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="2"/>
        </svg>
      </button>
    </nav>

    <div class="mobile-menu-overlay" aria-hidden="true">
      <nav class="mobile-menu-panel" aria-label="Mobile navigation">
        <button class="mobile-close" aria-label="Close menu">✕</button>
        <div class="mobile-menu-links">
          {
            navLinks.map((item) => (
              <a class:list={{ current: isCurrent(item.href) }} href={item.href}>
                {item.label}
              </a>
            ))
          }
          <a href={whatsappUrl} class="nav-cta" target="_blank" rel="noopener">Join WhatsApp <span class="inline-arrow" aria-hidden="true">▶</span></a>
        </div>
      </nav>
    </div>

    <div class="home-shell">
      <main class="home-main">
        <div class="logo" data-logo-reanimate data-logo-reveal-duration={taglineEndSec.toFixed(3)}>
          <div class="ascii" set:html={asciiAnimatedHtml}></div>
          <div
            class="rule logo-rule"
            data-logo-cycle
            data-logo-rule
            style={`color:#d8e4f8;--logo-del:${ruleRevealDelaySec.toFixed(3)}s;--logo-rule-dur:${RULE_DRAW_SEC}s`}
          >
            ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄
          </div>
          <div class="tagline" set:html={taglineAnimatedHtml}></div>
        </div>
      </main>

      <!-- Hero tagline + CTAs -->
      <section class="home-hero-section">
        <p class="home-hero-tagline">A Singapore community of builders exploring agentic coding with Claude Code, Codex, Antigravity, and beyond.</p>
        <div class="home-hero-ctas">
          <a class="button button-primary" href={whatsappUrl} target="_blank" rel="noopener">Join the Chat</a>
          <a class="button button-secondary" href="#getting-started">Get Started ↓</a>
        </div>
        <div class="home-recap-notice">
          <p>New: <a class="muted-link" href={`/events/#${latestRecap.id}`}>Listen to the AI-generated recap: {latestRecap.title.replace(/^#\d+\s*[-–—]\s*/, "")}</a></p>
        </div>
      </section>

      <!-- Upcoming Event -->
      <section class="home-section">
        <h3 class="section-label">Upcoming Event</h3>
        {upcomingEvent ? (
          <div class="list-item">
            <div class="list-item-header">
              <span class="list-item-title">{upcomingEvent.data.title}</span>
              <div class="card-meta">
                <span>{new Date(upcomingEvent.data.date).toLocaleDateString("en-SG", { weekday: "short", year: "numeric", month: "short", day: "numeric" })}</span>
                {upcomingEvent.data.time && <span>{upcomingEvent.data.time}</span>}
                {upcomingEvent.data.venue && <span>{upcomingEvent.data.venue}</span>}
              </div>
            </div>
            {upcomingEvent.data.registrationUrl && (
              <a class="button button-primary home-event-register" href={upcomingEvent.data.registrationUrl} target="_blank" rel="noopener">Register <span class="inline-arrow" aria-hidden="true">▶</span></a>
            )}
          </div>
        ) : (
          <div class="card">
            <p>No upcoming events — <a href={whatsappUrl} target="_blank" rel="noopener" style="color:var(--accent);">join the WhatsApp chat</a> to stay updated, or <a class="muted-link" href={contributionLinks.event} target="_blank" rel="noopener">add an event by submitting a pull request</a>.</p>
          </div>
        )}
      </section>

      <!-- Getting Started -->
      <section class="home-section" id="getting-started">
        <h3 class="section-label">Getting Started</h3>
        <div class="grid columns-2">
          <div class="person-card">
